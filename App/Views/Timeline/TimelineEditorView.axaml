<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Storyboard.ViewModels.Timeline"
             xmlns:m="using:Storyboard.Models"
             xmlns:tm="using:Storyboard.Models.Timeline"
             xmlns:v="using:Storyboard.Views.Timeline"
             xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
             xmlns:conv="using:Storyboard.Converters"
             xmlns:controls="using:Storyboard.Controls"
             x:Class="Storyboard.Views.Timeline.TimelineEditorView"
             x:DataType="vm:TimelineEditorViewModel"
             Focusable="True">

    <UserControl.Resources>
        <conv:PathToBitmapConverter x:Key="PathToBitmapConverter" />
        <conv:SubtractDoubleConverter x:Key="SubtractDoubleConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="*,Auto,Auto,*" Background="#0a0a0a">

        <!-- 1. 视频预览播放器 (50-60% 高度) -->
        <Border Grid.Row="0"
                Background="#0f0f0f"
                BorderBrush="#27272a"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid RowDefinitions="Auto,*">
                <!-- 标题栏 -->
                <TextBlock Grid.Row="0"
                           Text="视频预览"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#f5f5f5"
                           Margin="0,0,0,12" />

                <!-- 视频播放器 -->
                <Border Grid.Row="1"
                        Background="#000000"
                        CornerRadius="8"
                        ClipToBounds="True">
                    <vlc:VideoView x:Name="VideoPlayer"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />
                </Border>
            </Grid>
        </Border>

        <!-- 2. 播放控制栏 -->
        <Border Grid.Row="1"
                Background="#0f0f0f"
                BorderBrush="#27272a"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- 播放按钮 -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Command="{Binding PlayFromTimelineCommand}"
                            IsEnabled="{Binding Playback.CanPlay}"
                            Classes="Ghost"
                            Width="32"
                            Height="32"
                            Padding="6">
                        <PathIcon Data="M8 5v14l11-7z"
                                  Width="16"
                                  Height="16"
                                  Foreground="#f5f5f5" />
                    </Button>
                    <Button Command="{Binding Playback.PauseCommand}"
                            IsEnabled="{Binding Playback.CanPause}"
                            Classes="Ghost"
                            Width="32"
                            Height="32"
                            Padding="6">
                        <PathIcon Data="M6 4h4v16H6V4zm8 0h4v16h-4V4z"
                                  Width="16"
                                  Height="16"
                                  Foreground="#f5f5f5" />
                    </Button>
                    <Button Command="{Binding Playback.StopCommand}"
                            Classes="Ghost"
                            Width="32"
                            Height="32"
                            Padding="6">
                        <PathIcon Data="M6 6h12v12H6z"
                                  Width="16"
                                  Height="16"
                                  Foreground="#f5f5f5" />
                    </Button>
                </StackPanel>

                <!-- 进度条 -->
                <Slider Grid.Column="1"
                        Minimum="0"
                        Maximum="{Binding TotalDuration}"
                        Value="{Binding PlayheadTime, Mode=TwoWay}"
                        Margin="16,0"
                        VerticalAlignment="Center" />

                <!-- 时间码 -->
                <TextBlock Grid.Column="2"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="#a1a1aa"
                           VerticalAlignment="Center">
                    <Run Text="{Binding Playback.State.TimeCode}" />
                    <Run Text=" / " />
                    <Run Text="{Binding Playback.State.TotalTimeCode}" />
                </TextBlock>
            </Grid>
        </Border>

        <!-- 3. 时间轴工具栏 -->
        <Border Grid.Row="2"
                Background="#0f0f0f"
                BorderBrush="#27272a"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- 左侧：添加轨道 -->
                <Button Grid.Column="0"
                        Command="{Binding AddTrackCommand}"
                        CommandParameter="{x:Static tm:TrackType.Video}"
                        Classes="Ghost">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                                  Width="16"
                                  Height="16"
                                  Foreground="#a1a1aa" />
                        <TextBlock Text="添加轨道"
                                   FontSize="12"
                                   Foreground="#a1a1aa" />
                    </StackPanel>
                </Button>

                <!-- 中间：切割 -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Center">
                    <Button Command="{Binding SplitSelectedClipCommand}"
                            Classes="Ghost">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="M4 4h4v4H4zM16 16h4v4h-4zM6 6l12 12"
                                      Width="14"
                                      Height="14"
                                      Foreground="#a1a1aa" />
                            <TextBlock Text="切割"
                                       FontSize="12"
                                       Foreground="#a1a1aa" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 右侧：缩放控制 -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="12">
                    <TextBlock Text="缩放:"
                               FontSize="12"
                               Foreground="#a1a1aa"
                               VerticalAlignment="Center" />

                    <Slider Minimum="10"
                            Maximum="200"
                            Width="160"
                            Value="{Binding PixelsPerSecond, Mode=TwoWay}"
                            VerticalAlignment="Center" />

                    <TextBlock Text="{Binding PixelsPerSecond, StringFormat='{}{0:0}px/s'}"
                               FontSize="12"
                               Foreground="#a1a1aa"
                               VerticalAlignment="Center"
                               Width="60" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 4. 时间轴画布 (40-50% 高度) -->
        <Grid Grid.Row="3" ColumnDefinitions="120,*">

            <!-- 左侧：轨道头部列表（固定，只垂直滚动） -->
            <Border Grid.Column="0"
                    Background="#0f0f0f"
                    BorderBrush="#27272a"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="32,*">
                    <!-- 轨道头部占位符（对齐刻度尺高度） -->
                    <Border Grid.Row="0"
                            Height="32"
                            Background="#0f0f0f"
                            BorderBrush="#27272a"
                            BorderThickness="0,0,0,1"
                            BoxShadow="0 2 4 0 #00000040" />

                    <!-- 轨道头部列表 -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="TrackHeadersScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalContentAlignment="Stretch">
                        <ItemsControl ItemsSource="{Binding Tracks}"
                                      Height="{Binding TracksHeight}"
                                      HorizontalAlignment="Stretch">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Height="{Binding $parent[ItemsControl].Height}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.Styles>
                                <Style Selector="ItemsControl > ContentPresenter" x:DataType="tm:TimelineTrack">
                                    <Setter Property="Canvas.Left" Value="0" />
                                    <Setter Property="Canvas.Top" Value="{Binding VerticalOffset}" />
                                    <Setter Property="Width" Value="{Binding $parent[ItemsControl].Bounds.Width}" />
                                    <Setter Property="Height" Value="{Binding Height}" />
                                </Style>
                            </ItemsControl.Styles>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="tm:TimelineTrack">
                                    <!-- 只显示轨道头部，不包含内容区 -->
                                    <Border Background="#0f0f0f"
                                            BorderBrush="#27272a"
                                            BorderThickness="0,0,0,1"
                                            Padding="8"
                                            Height="{Binding Height}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                                <GradientStop Color="#0f0f0f" Offset="0" />
                                                <GradientStop Color="#0a0a0a" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid RowDefinitions="Auto,Auto,*">
                                            <!-- 轨道类型图标 -->
                                            <PathIcon Grid.Row="0"
                                                      Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-8 12H9.5v-2h-2v2H6V9h1.5v2.5h2V9H11v6zm7-1c0 .55-.45 1-1 1h-.75v1.5h-1.5V15H14c-.55 0-1-.45-1-1v-4c0-.55.45-1 1-1h3c.55 0 1 .45 1 1v4zm-3.5-.5h2v-3h-2v3z"
                                                      Width="24"
                                                      Height="24"
                                                      Foreground="#8b5cf6"
                                                      HorizontalAlignment="Left" />

                                            <!-- 轨道名称 -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Name}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,6,0,0" />

                                            <!-- 控制按钮 -->
                                            <StackPanel Grid.Row="2"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        VerticalAlignment="Bottom">
                                                <!-- 锁定按钮 -->
                                                <Button Classes="IconButton"
                                                        Width="24"
                                                        Height="24"
                                                        Padding="4"
                                                        Command="{Binding ToggleLockCommand}">
                                                    <PathIcon Data="{Binding IsLocked, Converter={x:Static conv:BoolConverters.LockIcon}}"
                                                              Width="14"
                                                              Height="14"
                                                              Foreground="{Binding IsLocked, Converter={x:Static conv:BoolConverters.LockColor}}" />
                                                </Button>

                                                <!-- 可见性按钮 -->
                                                <Button Classes="IconButton"
                                                        Width="24"
                                                        Height="24"
                                                        Padding="4"
                                                        Command="{Binding ToggleVisibilityCommand}">
                                                    <PathIcon Data="{Binding IsVisible, Converter={x:Static conv:BoolConverters.VisibilityIcon}}"
                                                              Width="14"
                                                              Height="14"
                                                              Foreground="{Binding IsVisible, Converter={x:Static conv:BoolConverters.VisibilityColor}}" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 右侧：刻度尺 + 时间轴内容 -->
            <Grid Grid.Column="1" RowDefinitions="32,*">

                <!-- 刻度尺（固定在顶部，不参与垂直滚动） -->
                <Border Grid.Row="0"
                        Background="#0f0f0f"
                        BorderBrush="#27272a"
                        BorderThickness="0,0,0,1"
                        BoxShadow="0 2 4 0 #00000040">
                    <controls:TimelineRulerControl x:Name="TimelineRuler"
                                                   Height="32"
                                                   HorizontalAlignment="Stretch"
                                                   PixelsPerSecond="{Binding PixelsPerSecond}"
                                                   TotalDuration="{Binding TotalDuration}"
                                                   PlayheadPosition="{Binding PlayheadPosition}"
                                                   SeekCommand="{Binding SeekToTimeCommand}"
                                                   ViewportOffsetX="{Binding #TimelineScrollViewer.Offset.X}" />
                </Border>

                <!-- 时间轴内容区（可滚动） -->
                <ScrollViewer Grid.Row="1"
                              x:Name="TimelineScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0"
                              HorizontalContentAlignment="Left"
                              VerticalContentAlignment="Top">
                    <Canvas Width="{Binding TimelineWidth}"
                            Height="{Binding TracksHeight}"
                            HorizontalAlignment="Left">

                        <!-- 背景网格线 -->
                        <controls:TimelineGridControl Width="{Binding TimelineWidth}"
                                                      Height="{Binding TracksHeight}"
                                                      PixelsPerSecond="{Binding PixelsPerSecond}"
                                                      Tracks="{Binding Tracks}" />

                        <!-- 轨道内容 -->
                        <ItemsControl ItemsSource="{Binding Tracks}"
                                      Width="{Binding TimelineWidth}"
                                      Height="{Binding TracksHeight}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding TimelineWidth}"
                                            Height="{Binding TracksHeight}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.Styles>
                                <Style Selector="ItemsControl > ContentPresenter" x:DataType="tm:TimelineTrack">
                                    <Setter Property="Canvas.Left" Value="0" />
                                    <Setter Property="Canvas.Top" Value="{Binding VerticalOffset}" />
                                    <Setter Property="Width" Value="{Binding $parent[ItemsControl].Width}" />
                                    <Setter Property="Height" Value="{Binding Height}" />
                                </Style>
                            </ItemsControl.Styles>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="tm:TimelineTrack">
                                    <!-- 只显示轨道内容区，不包含头部 -->
                                    <ItemsControl ItemsSource="{Binding Clips}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Width="{Binding $parent[UserControl].((vm:TimelineEditorViewModel)DataContext).TimelineWidth}"
                                                        Height="{Binding Height}" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.Styles>
                                            <Style Selector="ItemsControl > ContentPresenter" x:DataType="tm:TimelineClip">
                                                <Setter Property="Canvas.Left" Value="{Binding PixelPosition}" />
                                                <Setter Property="Canvas.Top" Value="8" />
                                                <Setter Property="Width" Value="{Binding PixelWidth}" />
                                                <Setter Property="Height" Value="72" />
                                            </Style>
                                        </ItemsControl.Styles>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="tm:TimelineClip">
                                                <v:TimelineClipView />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 吸附线指示器 -->
                        <Border Canvas.Left="{Binding SnapLinePosition}"
                                Canvas.Top="0"
                                Width="2"
                                Height="{Binding TracksHeight}"
                                Background="#8b5cf6"
                                Opacity="0.6"
                                IsVisible="{Binding SnapLinePosition, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>

                        <!-- 拖动幽灵预览 -->
                        <Border IsVisible="{Binding IsGhostPreviewVisible}"
                                Canvas.Left="{Binding GhostPreviewX}"
                                Canvas.Top="{Binding GhostPreviewY}"
                                Width="{Binding GhostPreviewWidth}"
                                Height="72"
                                Background="#27272a"
                                BorderBrush="#8b5cf6"
                                BorderThickness="2"
                                CornerRadius="2"
                                Opacity="0.5"
                                BoxShadow="0 4 12 0 #8b5cf680">
                            <Grid RowDefinitions="Auto,*">
                                <!-- 标题栏 -->
                                <Border Grid.Row="0"
                                        Background="#18181b"
                                        Padding="4,2"
                                        CornerRadius="2,2,0,0">
                                    <TextBlock Text="{Binding GhostPreviewLabel}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#f5f5f5" />
                                </Border>

                                <!-- 缩略图 -->
                                <Border Grid.Row="1"
                                        Margin="2"
                                        CornerRadius="1"
                                        ClipToBounds="True">
                                    <Border.Background>
                                        <ImageBrush Source="{Binding GhostPreviewThumbnail, Converter={StaticResource PathToBitmapConverter}}"
                                                   Stretch="UniformToFill"
                                                   TileMode="Tile"
                                                   DestinationRect="0,0,80,60"
                                                   AlignmentX="Left"
                                                   AlignmentY="Center" />
                                    </Border.Background>
                                </Border>
                            </Grid>
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>

                        <!-- 拖动提示框（胶囊形状） -->
                        <Border IsVisible="{Binding IsDragTooltipVisible}"
                                Background="#18181b"
                                BorderBrush="#8b5cf6"
                                BorderThickness="1.5"
                                CornerRadius="12"
                                Padding="12,6"
                                BoxShadow="0 4 16 0 #00000099"
                                Canvas.Left="{Binding DragTooltipX}"
                                Canvas.Top="{Binding DragTooltipY}">
                            <TextBlock Text="{Binding DragTooltipTime}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="#f5f5f5"
                                       FontWeight="SemiBold"
                                       LetterSpacing="0.5" />
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>

                        <!-- 吸附反馈提示框 -->
                        <Border IsVisible="{Binding IsSnapFeedbackVisible}"
                                Background="#18181b"
                                BorderBrush="#10b981"
                                BorderThickness="1.5"
                                CornerRadius="10"
                                Padding="10,5"
                                BoxShadow="0 4 16 0 #00000099"
                                Canvas.Left="{Binding SnapFeedbackX}"
                                Canvas.Top="{Binding SnapFeedbackY}">
                            <TextBlock Text="{Binding SnapFeedbackText}"
                                       FontSize="11"
                                       Foreground="#10b981"
                                       FontWeight="SemiBold" />
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                    </Canvas>
                </ScrollViewer>

                <!-- 播放头贯通线（从刻度到轨道底部） -->
                <Grid Grid.RowSpan="2"
                      IsHitTestVisible="False"
                      ClipToBounds="True">
                    <Border Width="2"
                            Background="#8b5cf6"
                            Opacity="0.85"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            BoxShadow="0 0 6 1 #8b5cf640">
                        <Border.RenderTransform>
                            <TranslateTransform>
                                <TranslateTransform.X>
                                    <MultiBinding Converter="{StaticResource SubtractDoubleConverter}">
                                        <Binding Path="PlayheadPosition" />
                                        <Binding Path="#TimelineScrollViewer.Offset.X" />
                                    </MultiBinding>
                                </TranslateTransform.X>
                            </TranslateTransform>
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
