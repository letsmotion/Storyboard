<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Storyboard.ViewModels"
             xmlns:conv="using:Storyboard.Converters"
             x:Class="Storyboard.Views.UpdateNotificationView"
             x:DataType="vm:UpdateNotificationViewModel">

  <UserControl.Resources>
    <conv:BooleanNotConverter x:Key="BoolNot" />
  </UserControl.Resources>

  <!-- 更新通知卡片 -->
  <Border IsVisible="{Binding IsUpdateAvailable}"
          Background="#18181b"
          BorderBrush="#3b82f6"
          BorderThickness="1"
          Padding="20"
          CornerRadius="12"
          Margin="16"
          BoxShadow="0 4 12 0 #00000040">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto">

      <!-- 标题行 -->
      <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
        <!-- 图标和标题 -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
          <Border Background="#3b82f6"
                  Width="40"
                  Height="40"
                  CornerRadius="20"
                  VerticalAlignment="Center">
            <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                      Width="24"
                      Height="24"
                      Foreground="White" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="发现新版本"
                       Foreground="#f5f5f5"
                       FontWeight="SemiBold"
                       FontSize="16"/>
            <TextBlock Foreground="#a1a1aa" FontSize="13" Margin="0,2,0,0">
              <Run Text="{Binding CurrentVersion, StringFormat='当前: {0}'}" />
              <Run Text=" → " />
              <Run Text="{Binding NewVersion}" Foreground="#3b82f6" FontWeight="Medium" />
            </TextBlock>
          </StackPanel>
        </StackPanel>

        <!-- 关闭按钮 -->
        <Button Grid.Column="2"
                Command="{Binding DismissUpdateCommand}"
                IsEnabled="{Binding IsDownloading, Converter={StaticResource BoolNot}}"
                Classes="Ghost"
                Width="32"
                Height="32"
                Padding="0"
                VerticalAlignment="Top">
          <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                    Width="16"
                    Height="16" />
        </Button>
      </Grid>

      <!-- 更新信息 -->
      <Grid Grid.Row="1" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="8" Margin="0,0,0,16">
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="更新大小:"
                   Foreground="#a1a1aa"
                   FontSize="13"
                   Margin="0,0,12,0" />
        <TextBlock Grid.Row="0" Grid.Column="1"
                   Text="{Binding UpdateSize}"
                   Foreground="#f5f5f5"
                   FontSize="13" />

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="更新类型:"
                   Foreground="#a1a1aa"
                   FontSize="13"
                   Margin="0,0,12,0" />
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Border Background="#10b981"
                  Padding="6,2"
                  CornerRadius="4"
                  IsVisible="{Binding IsDeltaUpdate}">
            <TextBlock Text="增量更新"
                       Foreground="White"
                       FontSize="11"
                       FontWeight="Medium" />
          </Border>
          <Border Background="#6366f1"
                  Padding="6,2"
                  CornerRadius="4"
                  IsVisible="{Binding IsDeltaUpdate, Converter={StaticResource BoolNot}}">
            <TextBlock Text="完整安装包"
                       Foreground="White"
                       FontSize="11"
                       FontWeight="Medium" />
          </Border>
        </StackPanel>
      </Grid>

      <!-- 下载进度 -->
      <StackPanel Grid.Row="2" Spacing="8" Margin="0,0,0,16" IsVisible="{Binding IsDownloading}">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding StatusMessage}"
                     Foreground="#a1a1aa"
                     FontSize="13" />
          <TextBlock Grid.Column="1"
                     Text="{Binding DownloadProgress, StringFormat='{}{0}%'}"
                     Foreground="#3b82f6"
                     FontSize="13"
                     FontWeight="Medium" />
        </Grid>
        <ProgressBar Value="{Binding DownloadProgress}"
                     Maximum="100"
                     Height="6"
                     Background="#27272a"
                     Foreground="#3b82f6"
                     CornerRadius="3" />
      </StackPanel>

      <!-- 错误消息 -->
      <Border Grid.Row="2"
              Background="#422006"
              BorderBrush="#78350f"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12"
              Margin="0,0,0,16"
              IsVisible="{Binding DownloadFailed}">
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                      Width="16"
                      Height="16"
                      Foreground="#fbbf24" />
            <TextBlock Text="下载失败"
                       FontWeight="SemiBold"
                       Foreground="#fbbf24" />
          </StackPanel>
          <TextBlock Text="{Binding ErrorMessage}"
                     TextWrapping="Wrap"
                     Foreground="#fcd34d"
                     FontSize="12" />
        </StackPanel>
      </Border>

      <!-- 操作按钮 -->
      <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
        <Button Grid.Column="0"
                Content="手动下载"
                Command="{Binding OpenDownloadPageCommand}"
                Classes="Ghost"
                HorizontalAlignment="Left"
                IsVisible="{Binding DownloadFailed}" />

        <Button Grid.Column="1"
                Content="稍后提醒"
                Command="{Binding RemindLaterCommand}"
                IsEnabled="{Binding IsDownloading, Converter={StaticResource BoolNot}}"
                Classes="Ghost"
                IsVisible="{Binding DownloadCompleted, Converter={StaticResource BoolNot}}" />

        <Button Grid.Column="2"
                Command="{Binding DownloadAndInstallCommand}"
                IsEnabled="{Binding IsDownloading, Converter={StaticResource BoolNot}}"
                Classes="Primary"
                IsVisible="{Binding DownloadCompleted, Converter={StaticResource BoolNot}}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Data="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5 5-5-5 1.41-1.41L11 12.67V3h2z"
                      Width="16"
                      Height="16" />
            <TextBlock Text="立即更新" />
          </StackPanel>
        </Button>

        <TextBlock Grid.Column="2"
                   Text="✓ 准备重启..."
                   Foreground="#10b981"
                   FontWeight="Medium"
                   VerticalAlignment="Center"
                   IsVisible="{Binding DownloadCompleted}" />
      </Grid>

    </Grid>
  </Border>

</UserControl>
