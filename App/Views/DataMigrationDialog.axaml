<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Storyboard.ViewModels"
        x:Class="Storyboard.Views.DataMigrationDialog"
        x:DataType="vm:SettingsViewModel"
        Title="数据迁移"
        Width="600"
        Height="500"
        MinWidth="500"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#0f0f0f"
        Foreground="#f5f5f5"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#18181b"
                BorderBrush="#27272a"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Spacing="8">
                <TextBlock Text="数据迁移"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#f5f5f5" />
                <TextBlock Text="将数据和输出文件迁移到新位置"
                           FontSize="13"
                           Foreground="#a1a1aa" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="24">

                <!-- 警告提示 -->
                <Border Background="#422006"
                        BorderBrush="#78350f"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                      Width="20"
                                      Height="20"
                                      Foreground="#fbbf24" />
                            <TextBlock Text="重要提示"
                                       FontWeight="SemiBold"
                                       Foreground="#fbbf24" />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#fcd34d">
                            <Run Text="• 迁移过程中请勿关闭应用" />
                            <LineBreak />
                            <Run Text="• 确保目标磁盘有足够的空间" />
                            <LineBreak />
                            <Run Text="• 迁移完成后应用将自动重启" />
                            <LineBreak />
                            <Run Text="• 建议在迁移前备份重要数据" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 新数据库位置 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="新数据库位置"
                               Foreground="#f5f5f5"
                               FontWeight="Medium" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewDataDirectory}"
                                 Watermark="选择数据库存储位置"
                                 Background="#18181b"
                                 BorderBrush="#27272a"
                                 IsEnabled="{Binding !IsMigrating}" />
                        <Button Grid.Column="1"
                                Content="浏览..."
                                Margin="8,0,0,0"
                                Classes="Ghost"
                                IsEnabled="{Binding !IsMigrating}"
                                Click="BrowseDataDirectory_Click" />
                    </Grid>
                </StackPanel>

                <!-- 新输出文件位置 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="新输出文件位置"
                               Foreground="#f5f5f5"
                               FontWeight="Medium" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewOutputDirectory}"
                                 Watermark="选择输出文件存储位置"
                                 Background="#18181b"
                                 BorderBrush="#27272a"
                                 IsEnabled="{Binding !IsMigrating}" />
                        <Button Grid.Column="1"
                                Content="浏览..."
                                Margin="8,0,0,0"
                                Classes="Ghost"
                                IsEnabled="{Binding !IsMigrating}"
                                Click="BrowseOutputDirectory_Click" />
                    </Grid>
                </StackPanel>

                <!-- 迁移进度 -->
                <StackPanel Spacing="12" IsVisible="{Binding IsMigrating}">
                    <ProgressBar Value="{Binding MigrationProgress}"
                                 Maximum="100"
                                 Height="8"
                                 Background="#27272a"
                                 Foreground="#3b82f6" />
                    <TextBlock Text="{Binding MigrationStatus}"
                               Foreground="#a1a1aa"
                               TextAlignment="Center" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="#18181b"
                BorderBrush="#27272a"
                BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12">
                <Button Content="取消"
                        Command="{Binding CloseMigrationDialogCommand}"
                        IsEnabled="{Binding !IsMigrating}"
                        Classes="Ghost" />
                <Button Content="开始迁移"
                        Command="{Binding StartMigrationCommand}"
                        IsEnabled="{Binding !IsMigrating}"
                        Classes="Primary" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
