<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Storyboard.ViewModels"
        x:Class="Storyboard.Views.TextToShotDialog"
        x:DataType="vm:MainViewModel"
        Title="文本生成分镜"
        Width="900"
        Height="620"
        WindowStartupLocation="CenterOwner"
        Background="#0a0a0a"
        CanResize="True"
        MinWidth="720"
        MinHeight="520">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="文本生成分镜"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#f5f5f5"
                       Margin="0,0,0,8" />
            <TextBlock Text="描述您的故事，生成分镜脚本"
                       FontSize="14"
                       Foreground="#71717a" />
        </StackPanel>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#000000dd"
                IsVisible="{Binding IsGeneratingShots}"
                CornerRadius="8"
                ZIndex="100">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20">
                <!-- Spinning loader -->
                <Border Width="48"
                        Height="48"
                        BorderThickness="4"
                        CornerRadius="24"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#8b5cf6" Offset="0" />
                            <GradientStop Color="#a78bfa" Offset="0.5" />
                            <GradientStop Color="#8b5cf6" Offset="1" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.RenderTransform>
                        <RotateTransform />
                    </Border.RenderTransform>
                    <Border.Styles>
                        <Style Selector="Border">
                            <Style.Animations>
                                <Animation Duration="0:0:1" IterationCount="Infinite">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="RotateTransform.Angle" Value="0" />
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="RotateTransform.Angle" Value="360" />
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Border.Styles>
                </Border>

                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="正在生成分镜..."
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#f5f5f5"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="AI 正在分析您的故事并生成分镜脚本"
                               FontSize="14"
                               Foreground="#a1a1aa"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1"
                Background="#18181b"
                BorderBrush="#27272a"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="描述您的故事"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#f5f5f5" />
                    <TextBlock Grid.Column="1"
                               FontSize="12"
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{Binding IsTextToShotPromptTooLong, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#ef4444|#71717a'}" />
                        </TextBlock.Foreground>
                        <Run Text="{Binding TextToShotPromptLength}" />
                        <Run Text="/" />
                        <Run Text="{Binding TextToShotPromptMaxLength}" />
                    </TextBlock>
                </Grid>

                <TextBox Grid.Row="1"
                         Text="{Binding TextToShotPrompt, Mode=TwoWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="320"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Watermark="例如:一个关于未来城市的科幻短片,主角在清晨的街道上行走,发现了一个神秘的装置..."
                         Background="#0a0a0a"
                         BorderThickness="1"
                         CornerRadius="8"
                         Foreground="#f5f5f5"
                         Padding="12"
                         Margin="0,12,0,0">
                    <TextBox.BorderBrush>
                        <SolidColorBrush Color="{Binding IsTextToShotPromptTooLong, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#ef4444|#27272a'}" />
                    </TextBox.BorderBrush>
                </TextBox>

                <TextBlock Grid.Row="2"
                           IsVisible="{Binding IsTextToShotPromptTooLong}"
                           Text="内容过长,请精简描述或分批生成"
                           FontSize="12"
                           Foreground="#ef4444"
                           Margin="0,4,0,0" />

                <Grid Grid.Row="3"
                      ColumnDefinitions="Auto,*"
                      Margin="0,12,0,0">
                    <TextBlock Text="生成数量"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#f5f5f5"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <NumericUpDown Value="{Binding TextToShotCount, Mode=TwoWay}"
                                       Minimum="1"
                                       Maximum="12"
                                       Width="120"
                                       Height="36"
                                       Background="#0a0a0a"
                                       BorderBrush="#27272a"
                                       Foreground="#f5f5f5"
                                       CornerRadius="8" />
                        <TextBlock Text="(1-12个分镜)"
                                   FontSize="12"
                                   Foreground="#71717a"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <Button Grid.Row="4"
                        Classes="Primary"
                        HorizontalAlignment="Stretch"
                        Click="OnGenerateClick"
                        IsEnabled="{Binding CanGenerateShots}"
                        Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                  Width="16" Height="16" />
                        <TextBlock Text="生成分镜" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,20,0,0">
            <TextBlock Grid.Column="0"
                       Foreground="#71717a"
                       VerticalAlignment="Center"
                       Text="生成后会追加到当前分镜列表末尾" />
        </Grid>

    </Grid>
</Window>
